# Backend Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# Database
MONGODB_URI=mongodb://localhost:27017/kim-th
DATABASE_NAME=kim-th

# Payment Gateway (Opn/Omise, GB Prime Pay, ฯลฯ)
PAYMENT_GATEWAY_KEY=your_payment_gateway_key_here
PAYMENT_GATEWAY_SECRET=your_payment_gateway_secret_here
PAYMENT_GATEWAY_WEBHOOK_SECRET=your_webhook_secret_here

# PromptPay Merchant ID
PROMPTPAY_MERCHANT_ID=your_merchant_id_here

# Frontend URLs
DONATION_PAGE_URL=http://localhost:3001/donation
OVERLAY_PAGE_URL=http://localhost:3001/overlay

# JWT Secret (Optional, for future authentication)
JWT_SECRET=your_jwt_secret_key_here

# Webhook Endpoint
WEBHOOK_ENDPOINT=/api/webhook/payment